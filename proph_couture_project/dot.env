# ==========================================
# CONFIGURATION POUR L'APPLICATION EN LIGNE (PRODUCTION)
# ==========================================

# URLs du Frontend (pour autoriser les requêtes CORS et CSRF)
FRONTEND_URL=https://votre-domaine-frontend.com

# URL de la base de données (Utilisé principalement sur Render, Heroku, etc.)
# Format PostgreSQL: postgres://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgres://votre_utilisateur:votre_mot_de_passe@votre_hote:5432/votre_nom_de_bdd

# Option alternatif pour base de données relationnelle si DATABASE_URL n'est pas utilisé
DATABASE_ENGINE=postgresql 
DB_NAME=votre_nom_bdd_en_ligne
DB_USER=votre_utilisateur_bdd
DB_PASSWORD=votre_mot_de_passe_bdd
DB_HOST=votre_hote_bdd_en_ligne
DB_PORT=5432

# Configuration des E-mails (ex: mot de passe d'application Gmail)
EMAIL_HOST_PASSWORD=votre_mot_de_passe_application_email

# Authentification Sociale
GOOGLE_OAUTH_SECRET=votre_secret_client_google

# Configuration des Paiements (Nelsius - Clés de Production)
NELSIUS_API_KEY=pk_live_votre_cle_api_en_ligne
NELSIUS_SECRET_KEY=sk_live_votre_cle_secrete_en_ligne
NELSIUS_WEBHOOK_SECRET=whsec_votre_secret_webhook_en_ligne

# Configuration SMS
SMS_API_URL=https://api.votre-fournisseur-sms.com/send
SMS_API_KEY=votre_cle_api_authentification_sms
SMS_SENDER_ID=ProphCouture
